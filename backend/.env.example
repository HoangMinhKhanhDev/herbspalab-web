# Server
PORT=5000
NODE_ENV=production

# MongoDB Atlas
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/herbspalab?retryWrites=true&w=majority

# JWT
JWT_SECRET=your_super_secure_jwt_secret_change_this_in_production

# CORS - Danh sách domain được phép (phân cách bằng dấu phẩy)
CORS_ORIGIN=https://herbspalab.com,https://www.herbspalab.com
