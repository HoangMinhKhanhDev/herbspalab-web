# ─── Server ───────────────────────────────────────────
# Local dev only. Hostinger Passenger sẽ tự gán PORT động, KHÔNG set trên production.
PORT=5000
NODE_ENV=development

# ─── Database (SQLite + Prisma) ───────────────────────
# Local dev:
DATABASE_URL="file:./dev.db"
# Hostinger production (đường dẫn tuyệt đối, ĐỂ NGOÀI public_html nếu được):
# DATABASE_URL="file:/home/username/private/herbspalab.db"
# Hoặc trong server/prisma (đã được Apache .htaccess chặn truy cập):
# DATABASE_URL="file:/home/username/domains/herbspalab.com/public_html/server/prisma/dev.db"

# ─── JWT ──────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string

# ─── CORS - Danh sách domain được phép (phân cách bằng dấu phẩy) ───
CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# ─── Frontend URL (Stripe redirect, reset-password links) ───
FRONTEND_URL=https://yourdomain.com
DOMAIN=https://yourdomain.com

# ─── Stripe ───────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ─── Email (Nodemailer) ───────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your@email.com
MAIL_PASS=app_password_here
